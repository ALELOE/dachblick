---
const leistungen = [
  {
    title: 'Velux Fenster Austausch',
    body: 'Altes Fenster raus, neues rein. In nur 2 Stunden tauschen unsere zertifizierten Monteure Ihr altes Dachfenster gegen ein neues Velux-Modell — sauber, schnell und ohne Folgeschäden.',
    badge: 'Beliebteste Leistung',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M7 16V4m0 0L3 8m4-4l4 4"/><path d="M17 8v12m0 0l4-4m-4 4l-4-4"/></svg>`,
  },
  {
    title: 'Velux Neueinbau',
    body: 'Mehr Licht ins Dachgeschoss. Wir planen, liefern und montieren Ihr neues Velux Dachfenster — inklusive Rohbauöffnung, Abdichtung und Fertigstellung.',
    badge: null,
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>`,
  },
  {
    title: 'Zubehör & Rollläden',
    body: 'Velux Verdunkelungsrollos, Insektenschutz, Außenrollläden und elektrische INTEGRA Steuerung. Alles original Velux — passgenau für Ihr Fenster.',
    badge: null,
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="4" rx="1"/><rect x="2" y="10" width="20" height="4" rx="1"/><rect x="2" y="17" width="20" height="4" rx="1"/></svg>`,
  },
];
---

<section id="leistungen" class="py-24 lg:py-32 bg-white">
  <div class="max-w-[1440px] mx-auto px-6 lg:px-16">

    <div class="mb-14 lg:mb-16">
      <p class="text-[13px] font-medium tracking-[0.06em] uppercase text-brand/50 mb-4">Was wir anbieten</p>
      <h2 class="text-4xl lg:text-[50px] text-brand max-w-lg">Unsere Velux Leistungen</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      {leistungen.map(({ title, body, badge, icon }) => (
        <div class="bg-cream rounded-[34px] p-8 lg:p-10 flex flex-col gap-6 hover:-translate-y-0.5 transition-transform duration-[220ms]">
          <div class="flex items-start justify-between gap-4">
            <div class="text-brand">
              <Fragment set:html={icon} />
            </div>
            {badge && (
              <span class="bg-brand text-white rounded-full px-3 py-1 text-[12px] font-medium tracking-[0.04em] shrink-0">
                {badge}
              </span>
            )}
          </div>
          <div>
            <h3 class="text-[22px] font-medium text-brand mb-3">{title}</h3>
            <p class="text-[16px] text-brand/70 leading-relaxed">{body}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
