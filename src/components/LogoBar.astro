---
---

<section class="bg-cream-pale py-12 lg:py-16 border-y border-cream">
  <div class="max-w-[1440px] mx-auto px-6 lg:px-16">
    <div class="flex flex-col lg:flex-row items-center justify-center gap-8 lg:gap-16 text-center lg:text-left">

      <!-- Velux partner badge -->
      <div class="flex items-center gap-4">
        <div class="bg-velux-red px-3 py-2 shrink-0" aria-label="Velux Logo">
          <span class="text-white text-[18px] font-bold tracking-[0.1em]">VELUX</span>
        </div>
        <div>
          <p class="text-[13px] font-medium tracking-[0.06em] uppercase text-brand/50">Autorisierter</p>
          <p class="text-[18px] font-medium text-brand">Velux Partner</p>
        </div>
      </div>

      <div class="hidden lg:block w-px h-10 bg-cream-muted"></div>

      <!-- Stars -->
      <div class="flex items-center gap-3">
        <div class="flex gap-0.5 text-amber-400 text-[20px]" aria-label="5 von 5 Sternen">
          ★★★★★
        </div>
        <div>
          <p class="text-[13px] font-medium tracking-[0.06em] uppercase text-brand/50">Bewertung</p>
          <p class="text-[18px] font-medium text-brand">4,9 / 5 Sterne</p>
        </div>
      </div>

      <div class="hidden lg:block w-px h-10 bg-cream-muted"></div>

      <!-- Customers stat -->
      <div>
        <p class="text-[13px] font-medium tracking-[0.06em] uppercase text-brand/50">Unsere Kunden</p>
        <p class="text-[18px] font-medium text-brand">Hunderte zufriedene Kunden</p>
      </div>

      <div class="hidden lg:block w-px h-10 bg-cream-muted"></div>

      <!-- Guarantee -->
      <div>
        <p class="text-[13px] font-medium tracking-[0.06em] uppercase text-brand/50">Garantie</p>
        <p class="text-[18px] font-medium text-brand">10 Jahre auf Einbau</p>
      </div>

    </div>
  </div>
</section>
