---
const year = new Date().getFullYear();
---

<footer class="bg-brand-deep text-white">
  <div class="max-w-[1440px] mx-auto px-6 lg:px-16 pt-16 lg:pt-20 pb-10">

    <!-- Top grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 mb-16">

      <!-- Brand -->
      <div class="lg:col-span-1">
        <a href="/" class="text-[28px] font-medium text-white tracking-[-0.01em] block mb-4">Dachblick</a>
        <p class="text-[15px] text-white/60 leading-relaxed max-w-[220px]">
          Ihr Spezialist für Velux Dachfenster — Austausch, Neueinbau und Zubehör.
        </p>
      </div>

      <!-- Leistungen -->
      <div>
        <p class="text-[13px] font-medium tracking-[0.06em] uppercase text-white/50 mb-5">Service</p>
        <ul class="space-y-3">
          <li><a href="#angebot" class="text-[16px] text-white/80 hover:text-white transition-colors duration-[140ms]">Kostenlos anfragen</a></li>
          <li><a href="#leistungen" class="text-[16px] text-white/80 hover:text-white transition-colors duration-[140ms]">Leistungen</a></li>
          <li><a href="#ablauf" class="text-[16px] text-white/80 hover:text-white transition-colors duration-[140ms]">Ablauf</a></li>
          <li><a href="#faq" class="text-[16px] text-white/80 hover:text-white transition-colors duration-[140ms]">FAQ</a></li>
        </ul>
      </div>

      <!-- Produkte -->
      <div>
        <p class="text-[13px] font-medium tracking-[0.06em] uppercase text-white/50 mb-5">Produkte</p>
        <ul class="space-y-3">
          <li><a href="#angebot" class="text-[16px] text-white/80 hover:text-white transition-colors duration-[140ms]">Velux Austausch</a></li>
          <li><a href="#angebot" class="text-[16px] text-white/80 hover:text-white transition-colors duration-[140ms]">Velux Neueinbau</a></li>
          <li><a href="#angebot" class="text-[16px] text-white/80 hover:text-white transition-colors duration-[140ms]">Velux Zubehör</a></li>
          <li><a href="#angebot" class="text-[16px] text-white/80 hover:text-white transition-colors duration-[140ms]">Rollläden & Rollos</a></li>
        </ul>
      </div>

      <!-- Recht -->
      <div>
        <p class="text-[13px] font-medium tracking-[0.06em] uppercase text-white/50 mb-5">Rechtliches</p>
        <ul class="space-y-3">
          <li><a href="/impressum" class="text-[16px] text-white/80 hover:text-white transition-colors duration-[140ms]">Impressum</a></li>
          <li><a href="/datenschutz" class="text-[16px] text-white/80 hover:text-white transition-colors duration-[140ms]">Datenschutz</a></li>
          <li><a href="/kontakt" class="text-[16px] text-white/80 hover:text-white transition-colors duration-[140ms]">Kontakt</a></li>
        </ul>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="border-t border-white/[0.08] pt-8">
      <p class="text-[14px] text-white/40">© {year} Dachblick · Alle Rechte vorbehalten</p>
    </div>

  </div>
</footer>
